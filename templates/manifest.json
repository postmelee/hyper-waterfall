{
  "schemaVersion": "0.1.0",
  "frameworkVersion": "0.2.0",
  "release": {
    "canonicalSource": "github-release",
    "plannedTag": "v0.2.0",
    "baselineTag": "v0.1.0",
    "status": "released"
  },
  "applicationMode": "adoption-only",
  "strictManifest": true,
  "localization": {
    "defaultLocale": "en",
    "supportedLocales": [
      "en",
      "ko",
      "zh-CN"
    ],
    "fallbackLocale": "en",
    "localePackRoot": "templates/locales",
    "sourcePatternToken": "{locale}",
    "missingLocalePolicy": "report-and-fallback-candidate",
    "preserveSelectedLocaleOnUpdate": true,
    "availability": {
      "status": "planned",
      "note": "Locale pack content is added by follow-up M050 tasks before release."
    }
  },
  "forbiddenTargetsOnAdoption": [
    "docs/**",
    "src/**",
    "examples/**",
    "schemas/**",
    "package.json",
    "tsconfig.json"
  ],
  "outOfScopeArtifactPolicy": "During adoption, record project-specific code, docs, architecture, roadmap, API contracts, examples, and schemas as deferred task candidates instead of creating or modifying files.",
  "versionState": {
    "targetPath": ".hyper-waterfall/version.json",
    "format": {
      "schemaVersion": "0.1.0",
      "frameworkVersion": "0.2.0",
      "source": "github-release",
      "releaseTag": "v0.2.0",
      "installedAt": "ISO-8601 timestamp",
      "updatedAt": "ISO-8601 timestamp"
    },
    "updatePolicy": "preserve"
  },
  "updatePolicies": {
    "overwrite": {
      "description": "Replace when the target still matches the previous framework checksum; treat local modifications as conflicts.",
      "requiresReviewOnConflict": true
    },
    "merge": {
      "description": "Create a patch and require human review before replacing user-visible or commonly customized files.",
      "requiresReviewOnConflict": true
    },
    "manual": {
      "description": "Do not update automatically; show the migration guide and require explicit maintainer action.",
      "requiresReviewOnConflict": true
    },
    "preserve": {
      "description": "Create when missing, then keep existing target content unless the maintainer explicitly approves a change.",
      "requiresReviewOnConflict": true
    },
    "symlink": {
      "description": "Ensure the target is a symlink to the expected path; prompt before replacing an existing file or directory.",
      "requiresReviewOnConflict": true
    }
  },
